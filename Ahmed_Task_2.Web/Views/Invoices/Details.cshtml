@model InvoiceVM

@{
    ViewData["Title"] = "Invoice";
}


<style>
    /* =========================
   SCREEN + PRINT STYLING
========================= */

body {
    font-family: "Segoe UI", Arial, sans-serif;
    font-size: 13px;
    color: #222;
    background: #f5f5f5;
}

.container {
    max-width: 1200px;
}

/* Main Invoice Card */

.card {
    border: 1px solid #dcdcdc !important;
    border-radius: 8px !important;
    overflow: hidden;
}

.card-header {
    background: #f8f9fa !important;
    border-bottom: 1px solid #dcdcdc !important;
}

.card-header h2,
.card-header h4 {
    margin: 0;
    font-weight: 600;
}

/* Header Information */

.row.mb-4 .col-md-3 {
    padding: 12px;
    border: 1px solid #eee;
}

.row.mb-4 strong {
    display: block;
    margin-bottom: 5px;
    color: #555;
}

/* Issuer & Receiver */

.card-body p {
    margin-bottom: 6px;
}

.card-body p strong {
    display: inline-block;
    min-width: 110px;
}

/* Tables */

table {
    width: 100%;
}

.table th {
    background: #f7f7f7;
    font-weight: 600;
}

.table th,
.table td {
    vertical-align: middle;
}

/* Invoice Line Cards */

.card.mb-4 {
    margin-bottom: 25px !important;
}

.card.mb-4 .card-header {
    font-size: 16px;
    font-weight: bold;
}

/* Totals Table */

.col-md-4 .table {
    border: 2px solid #333;
}

.col-md-4 .table th {
    width: 60%;
}

.col-md-4 .table tr:last-child {
    font-size: 16px;
    font-weight: bold;
}

/* Print Button */

button {
    min-width: 150px;
}

/* =========================
   PRINT STYLING
========================= */

@@page {
    size: A1;
    margin: 12mm;
}

@@media print {

    body {
        background: white !important;
        color: black !important;
        font-size: 11px;
    }

    .btn,
    button,
    nav,
    footer,
    .navbar,
    .breadcrumb {
        display: none !important;
    }

    .container {
        max-width: 100% !important;
        width: 100% !important;
        padding: 0 !important;
        margin: 0 !important;
    }

    .card {
        border: 1px solid #000 !important;
        box-shadow: none !important;
        margin-bottom: 10px !important;
        page-break-inside: avoid;
    }

    .card-header {
        background: #f0f0f0 !important;
        color: black !important;
        font-weight: bold;
        padding: 8px !important;
    }

    .row {
        page-break-inside: avoid;
    }

    table {
        page-break-inside: auto;
        border-collapse: collapse !important;
    }

    tr {
        page-break-inside: avoid;
    }

    th,
    td {
        border: 1px solid #000 !important;
        padding: 5px !important;
    }

    .table-borderless th,
    .table-borderless td {
        border: 1px solid #ddd !important;
    }

    .table-striped tbody tr:nth-of-type(odd) {
        background-color: #f8f8f8 !important;
    }

    h2 {
        font-size: 22px;
        font-weight: bold;
        margin-bottom: 15px;
    }

    h3 {
        font-size: 18px;
        margin-top: 15px;
    }

    h4 {
        font-size: 15px;
    }

    h5 {
        font-size: 13px;
    }

    .col-md-4 .table {
        width: 100%;
        margin-top: 15px;
    }
}




</style>

<div class="d-flex justify-content-between">
    <div></div>
    <button type="button" onclick="printInvoice()" class="btn btn-primary">Download PDF</button>
</div>

<div class="container my-4">

    <div class="card shadow-sm">

        <div class="card-header text-center">
            <h2>Invoice v1.0</h2>
        </div>

        <div class="card-body">

            <!-- Header -->
            <div class="row mb-4">

                <div class="col-md-3">
                    <strong>Internal Id</strong><br />
                    @Model.InternalId
                </div>

                <div class="col-md-3">
                    <strong>Date Issued</strong><br />
                    @Model.DateIssued
                </div>

                <div class="col-md-3">
                    <strong>Activity Code</strong><br />
                    @Model.ActivityCode
                </div>

                <div class="col-md-3">
                    <strong>Total Amount</strong><br />
                    @Model.TotalAmount.ToString("N5")
                </div>

            </div>

            <!-- Parties -->
            <div class="row mb-5">

                <div class="col-md-6">

                    <div class="card h-100">
                        <div class="card-header text-center">
                            <h4>Issuer</h4>
                        </div>

                        <div class="card-body">

                            <p><strong>Type:</strong> @Model.Issuer.Type</p>

                            <p><strong>ID:</strong> @Model.Issuer.RegistrationId</p>

                            <p><strong>Name:</strong> @Model.Issuer.Name</p>

                            <p><strong>Country:</strong> @Model.Issuer.Country</p>

                            <p><strong>Governorate:</strong> @Model.Issuer.Governorate</p>

                            <p><strong>City:</strong> @Model.Issuer.RegionCity</p>

                            <p><strong>Street:</strong> @Model.Issuer.Street</p>

                            <p><strong>Building:</strong> @Model.Issuer.BuildingNumber</p>

                            <p><strong>Branch:</strong> @Model.Issuer.BranchId</p>

                        </div>
                    </div>

                </div>

                <div class="col-md-6">

                    <div class="card h-100">
                        <div class="card-header text-center">
                            <h4>Receiver</h4>
                        </div>

                        <div class="card-body">

                            <p><strong>Type:</strong> @Model.Receiver.Type</p>

                            <p><strong>ID:</strong> @Model.Receiver.RegistrationId</p>

                            <p><strong>Name:</strong> @Model.Receiver.Name</p>

                            <p><strong>Country:</strong> @Model.Receiver.Country</p>

                            <p><strong>Governorate:</strong> @Model.Receiver.Governorate</p>

                            <p><strong>City:</strong> @Model.Receiver.RegionCity</p>

                            <p><strong>Street:</strong> @Model.Receiver.Street</p>

                            <p><strong>Building:</strong> @Model.Receiver.BuildingNumber</p>

                        </div>
                    </div>

                </div>

            </div>

            <!-- Lines -->
            <h3 class="mb-3">Invoice Lines</h3>

            @foreach (var line in Model.Lines)
            {
                <div class="card mb-4">

                    <div class="card-header">
                        <strong>@line.Description</strong>
                    </div>

                    <div class="card-body">

                        <div class="row">

                            <div class="col-md-6">

                                <table class="table table-borderless">

                                    <tr>
                                        <th>Item Code</th>
                                        <td>@line.ItemCode</td>
                                    </tr>

                                    <tr>
                                        <th>Quantity</th>
                                        <td>@line.Quantity.ToString("N5")</td>
                                    </tr>

                                    <tr>
                                        <th>Unit Type</th>
                                        <td>@line.UnitType</td>
                                    </tr>

                                    <tr>
                                        <th>Unit Price</th>
                                        <td>@line.UnitPrice.ToString("N5")</td>
                                    </tr>

                                    <tr>
                                        <th>Sales Total</th>
                                        <td>@line.SalesTotal.ToString("N5")</td>
                                    </tr>

                                    <tr>
                                        <th>Discount Per Unit</th>
                                        <td>@line.DiscountPerUnit.ToString("N5")</td>
                                    </tr>

                                    <tr>
                                        <th>Discount %</th>
                                        <td>@line.DiscountPercentage.ToString("N5")</td>
                                    </tr>

                                </table>

                            </div>

                            <div class="col-md-6">

                                <h5>Taxes</h5>

                                <table class="table table-sm table-striped">

                                    <thead>
                                        <tr>
                                            <th>Type</th>
                                            <th>Sub Type</th>
                                            <th>Rate</th>
                                            <th>Amount</th>
                                        </tr>
                                    </thead>

                                    <tbody>

                                        @foreach (var tax in line.Taxes)
                                        {
                                            <tr>
                                                <td>@tax.TaxType</td>
                                                <td>@tax.TaxSubType</td>
                                                <td>@tax.Rate.ToString("N5")</td>
                                                <td>@tax.Amount.ToString("N5")</td>
                                            </tr>
                                        }

                                    </tbody>

                                </table>

                            </div>

                        </div>

                    </div>

                </div>
            }

            <!-- Totals -->

            <div class="row justify-content-end">

                <div class="col-md-4">

                    <table class="table">

                        <tr>
                            <th>Net Amount</th>
                            <td>@Model.NetAmount.ToString("N5")</td>
                        </tr>

                        <tr>
                            <th>Total Amount</th>
                            <td>@Model.TotalAmount.ToString("N5")</td>
                        </tr>

                    </table>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    <script>
        function printInvoice() {
            window.print();
        }
    </script>
}